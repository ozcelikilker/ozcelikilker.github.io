	keywords = {Complexity theory, cryptographic accumulator, Cryptography, ECC, Elliptic curve cryptography, Intelligent systems, Internet of Things, IoT, Memory management, Performance evaluation, performance test, Real-time systems, Technological innovation, Testing},
	pages = {1--6},
	file = {Full Text PDF:C\:\\Users\\ozcel\\Zotero\\storage\\LWCCGEHM\\Toros vd. - 2024 - Performance Evaluation of ECC Based Cryptographic Accumulator on Resource-Constrained Platform.pdf:application/pdf},
