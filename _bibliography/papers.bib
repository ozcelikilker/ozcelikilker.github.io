@incollection{alagha_using_2025,
	title = {Using {Blockchain} {Technology} for {Audit} {Trail}},
	abstract = {An audit trail records activities and events that track changes within a system. Maintaining a reliable audit trail prevents fraud, manages data, and ensures control. Recent audit failures highlight the need for more reliable audit trails. Traditional methods face criticism due to their susceptibility to security breaches, inefficiencies, and high costs, which limit their effectiveness in real-time fraud detection. Studies emphasizing financial losses due to fraud underscore the necessity for improved systems. With its decentralized and immutable ledger, blockchain technology presents a promising alternative. It provides a tamper-proof, transparent, and real-time record of transactions, addressing traditional systems’ shortcomings. Blockchain features like immutability, and transparency can enhance audit quality, reduce fraud risks, and improve auditing efficiency. Blockchain-based audit trails outperform traditional systems by leveraging these features to enhance reliability, efficiency, and security. Government agencies and organizations adopt blockchain-based audit trails to create tamper-proof records, ensuring data reliability and availability while reducing fraud and increasing trust in such systems. Audit trails also play a critical role in monitoring online and utility services and evaluating the quality of service provided. This chapter examines blockchain’s potential to address traditional audit trail limitations, providing an overview of both domains and outlining blockchain’s benefits.},
	booktitle = {Digital {Strategy} and {Governance} in {Transformative} {Technologies}},
	publisher = {CRC Press},
	author = {Alagha, Bilal and Özçelik, İlker},
	year = {2025},
	note = {Num Pages: 21},
}

@article{karyagdi_botnet_2026,
	title = {Botnet {Node} {Detection} {Using} {Graph} {Learning}},
	volume = {16},
	copyright = {http://creativecommons.org/licenses/by/3.0/},
	issn = {2076-3417},
	url = {https://www.mdpi.com/2076-3417/16/1/24},
	doi = {10.3390/app16010024},
	abstract = {Botnets represent a persistent and significant threat to internet security. Many detection methods fail because they analyze isolated node data, neglecting the coordinated interactions of centrally managed bots. Graph-based methods, particularly Graph Neural Networks (GNNs), offer a promising solution. This study developed and compared four novel GNN models (HeteroGCN, HeteroGAT, HeteroSAGE, and HeteroGAE) for botnet detection. We constructed a heterogeneous graph from the TI-16 DNS-labeled dataset, capturing interactions between users and domains. Experimental results show our models achieve up to 95\% accuracy. Specifically, HeteroSAGE and HeteroGAE significantly outperform other models, demonstrating superior F1-Scores and exceptionally high Recall. This high recall, indicating a low false-negative rate, is critical for effective anomaly detection. Conversely, the computationally expensive HeteroGAT model yielded poorer results and slower inference times, demonstrating that increased model complexity does not guarantee better performance. To our knowledge, this is the first study to successfully apply and compare heterogeneous GNNs for bot detection using DNS query data.},
	language = {en},
	number = {1},
	urldate = {2026-04-07},
	journal = {Applied Sciences},
	author = {Karyağdı, Gizem and Özçelik, İlker},
	month = jan,
	year = {2026},
	note = {Publisher: Multidisciplinary Digital Publishing Institute},
	keywords = {botnet detection, GNN, graph neural networks, graph-based detection, heterogeneous graphs},
	pages = {24},
  selected={true},
	file = {Full Text PDF:C\:\\Users\\ozcel\\Zotero\\storage\\BYJ4XD6P\\Karyağdı ve Özçelik - 2026 - Botnet Node Detection Using Graph Learning.pdf:application/pdf},
}

@inproceedings{ozcelik_code-based_2025,
	title = {A {Code}-{Based} {Universal} {Cryptographic} {Accumulator}},
	url = {https://ieeexplore.ieee.org/abstract/document/11268188},
	doi = {10.1109/ISMSIT67332.2025.11268188},
	abstract = {In computer science and engineering, set membership tests are of critical importance in numerous areas, such as databases and verification systems. Traditional search algorithms become inefficient in terms of time and memory as the set size increases. To overcome these limitations, cryptographic accumulators, which are specialized data structures that perform set membership tests efficiently, have been proposed. Accumulators compress the values of a large set into a small value, offering the ability to effectively prove the existence of set elements. Cryptographic accumulators play an effective role in solving various problems such as privacy-preserving data sharing, verification of data integrity, and particularly authentication in areas like identity verification systems, blockchain, and pattern matching. Existing cryptographic accumulators are based on computationally challenging mathematical problems such as factoring large integers or discrete logarithms. However, with the development of quantum computers, the computational security of these algorithms has been compromised. In this study, a hash tree-based universal accumulator scheme was developed using a code-based cryptographic accumulator resistant to quantum attacks. This new scheme aims to ensure data security in the post-quantum era.},
	urldate = {2026-04-07},
	booktitle = {2025 9th {International} {Symposium} on {Multidisciplinary} {Studies} and {Innovative} {Technologies} ({ISMSIT})},
	author = {Özçelik, İlker},
	month = nov,
	year = {2025},
	note = {ISSN: 2770-7962},
	keywords = {Authentication, Blockchains, Code-Based Cryptography, Computer science, Cryptographic Accumulator, Cryptography, Data integrity, Data structures, Databases, Pattern matching, Post-Quantum, Quantum computing, Resistance, Universal Cryptographic Accumulator},
	pages = {1--5},
	file = {Full Text PDF:C\:\\Users\\ozcel\\Zotero\\storage\\LIVFX66H\\Özçelik - 2025 - A Code-Based Universal Cryptographic Accumulator.pdf:application/pdf},
}

@inproceedings{cekis_edge_2025,
	title = {Edge {Authentication} {Using} a {Cryptographic} {Accumulator}},
	url = {https://ieeexplore.ieee.org/abstract/document/11268018},
	doi = {10.1109/ISMSIT67332.2025.11268018},
	abstract = {Traditional authentication protocols, which rely on centralized identity providers, face significant challenges with latency and bandwidth consumption as modern information systems scale to a large number of users and real-time processing. Edge authentication offers a promising solution by shifting user verification to local devices, thereby reducing dependency on a central server. However, this approach requires a secure and efficient method for distributing authentication data to edge devices and ensuring a efficient verification process. This paper proposes a novel edge authentication protocol designed for efficiency and security, particularly for resource-constrained Internet of Things (IoT) devices. The protocol addresses the key challenges by leveraging a cryptographic accumulator. This data structure provides a compact and verifiable representation of the authentication database that can be securely distributed to edge devices. The core advantage is its ability to perform verification with an O(1) time complexity, which not only accelerates the process but also enables the system to operate effectively in low-bandwidth environments with a high number of users. The operational mechanism of this theoretical protocol is detailed, with future work planned for implementation and practical performance testing.},
	urldate = {2026-04-07},
	booktitle = {2025 9th {International} {Symposium} on {Multidisciplinary} {Studies} and {Innovative} {Technologies} ({ISMSIT})},
	author = {Çekiş, İsmet Kaan and Toros, Armağan and Yiğit, Volkan and Özçelik, İlker},
	month = nov,
	year = {2025},
	note = {ISSN: 2770-7962},
	keywords = {Authentication, cryptographic accumulator, Cryptography, edge authentication, Information systems, Internet of Things, latency, Performance evaluation, protocol design, Protocols, Real-time systems, Servers, Testing, Time complexity},
	pages = {1--5},
	file = {Full Text PDF:C\:\\Users\\ozcel\\Zotero\\storage\\FTUEPJ6J\\Çekiş vd. - 2025 - Edge Authentication Using a Cryptographic Accumulator.pdf:application/pdf},
}

@inproceedings{cetin_flowzen_2025,
