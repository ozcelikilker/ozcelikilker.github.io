	keywords = {Computer Science - Cryptography and Security},
	pages = {661--669},
	annote = {Comment: Note: This is an extended version of a paper published In Proceedings of the 7th International Conference on Information Systems Security and Privacy (ICISSP 2021), pages 661-669},
	file = {Preprint PDF:C\:\\Users\\ozcel\\Zotero\\storage\\X2ZV3L3M\\Ozcelik vd. - 2021 - An Overview of Cryptographic Accumulators.pdf:application/pdf;Snapshot:C\:\\Users\\ozcel\\Zotero\\storage\\X5HPBYSQ\\2103.html:text/html},
}

@inproceedings{ozcelik_cryptorevocate_2021,
