	doi = {10.1109/ISCTrkiye68593.2025.11224821},
	abstract = {The rapid acceleration of network digitalization and the growth of connected devices have amplified the need for scalable and efficient network traffic monitoring. Traditional monitoring solutions are often unfeasible in high-bandwidth environments due to high resource demands and latency. While flow-based approaches such as sFlow offer a scalable alternative, many existing open-source implementations have limitations, including incomplete protocol field support and poor performance under heavy traffic. The primary contribution of this work is the development of Flowzen, a novel network monitoring system that leverages real-time streaming architecture and a Horizontal Pod Autoscaling (HPA) mechanism to provide a scalable and resilient solution. By leveraging the HPA mechanism, the system demonstrates significant resilience, reducing packet loss from 52\% to just 2.5\% under high traffic loads and maintaining low latency where fixed-pod systems failed. While HPA proved effective in preventing bottlenecks, minor performance overhead was noted at low traffic levels. The paper details Flowzen's architecture, presents experimental findings, and concludes with a discussion of future work, including integration with NetFlow and IPFIX protocols and further optimization of dynamic scaling algorithms to enhance data consistency.},
	urldate = {2026-04-07},
	booktitle = {2025 18th {International} {Conference} on {Information} {Security} and {Cryptology} ({ISCTürkiye})},
	author = {Çetin, Furkan and Gültekin, Alperen and Çekiş, İsmet Kaan and Özgür, Mustafa and Özçelik, İlker},
	month = oct,
	year = {2025},
	keywords = {Autoscaling, Flowzen, Heuristic algorithms, Low latency communication, Monitoring, Network Monitoring, Packet loss, Protocols, Random access memory, Real-time systems, Resilience, Resource management, sFlow, Telecommunication traffic},
	pages = {1--6},
	file = {Full Text PDF:C\:\\Users\\ozcel\\Zotero\\storage\\38GNVQB7\\Çetin vd. - 2025 - Flowzen Modular and Scalable Network Monitoring Platform.pdf:application/pdf},
