	doi = {10.1109/GREE.2013.18},
	abstract = {In this study, we test anomaly based Denial of Service (DoS) detection approaches on networks with different utilization profiles. In the experiments, we use operational background traffic and performed Distributed DoS attackswithout disturbing the operational network. Experiment results indicate that the detection approach's detection performance is inversely proportional to network utilization and optimal detection parameters depend on network utilization.},
